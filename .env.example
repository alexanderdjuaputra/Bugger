# Copy this file to .env.local for local development if you prefer env
# vars over a serviceAccountKey.json file. This file itself is safe to
# commit — it contains no real secrets, only placeholder names.
#
# These three values come from Firebase Console -> Project Settings ->
# Service Accounts -> Generate new private key. See PANDUAN_DEPLOY.md
# for exact steps (Langkah 1-3).

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Optional: only set this if you're running the official Firestore
# emulator locally (firebase emulators:start --only firestore). When
# set, the two project/email/key vars above are ignored.
# FIRESTORE_EMULATOR_HOST=localhost:8080
