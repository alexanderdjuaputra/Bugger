rules_version = '2';

// This app never talks to Firestore directly from the browser — every
// read and write goes through your Vercel server using the Firebase
// ADMIN SDK, which always bypasses these rules regardless of what they
// say. These rules only matter for protecting against someone using
// the Firebase client SDK / REST API directly from outside your app,
// so we deny that entirely.
//
// Apply this in Firebase Console -> Firestore Database -> Rules, or
// deploy it with `firebase deploy --only firestore:rules` if you have
// the Firebase CLI installed. See PANDUAN_DEPLOY.md, "Langkah 2".
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
